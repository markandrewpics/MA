{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "blog.markandrewboudoir.com" }],
      "destination": "https://www.markandrewboudoir.com/blog",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "blog.markandrewboudoir.com" }],
      "destination": "https://www.markandrewboudoir.com/:path*",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "accept", "value": ".*text/markdown.*" }],
      "destination": "/index.md",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/index.md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Vary", "value": "Accept" }
      ]
    },
    {
      "source": "/auth.md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" }
      ]
    },
    {
      "source": "/.well-known/agent-skills/:skill/SKILL.md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "</sitemap.xml>; rel=\"describedby\"; type=\"application/xml\", </privacy-policy/>; rel=\"privacy-policy\", </terms-of-service/>; rel=\"terms-of-service\", </llms.txt>; rel=\"llms-txt\", </auth.md>; rel=\"auth-md\", </.well-known/agent-skills/index.json>; rel=\"agent-skills\"; type=\"application/json\""
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Link",
          "value": "</sitemap.xml>; rel=\"describedby\"; type=\"application/xml\", </privacy-policy/>; rel=\"privacy-policy\", </terms-of-service/>; rel=\"terms-of-service\", </llms.txt>; rel=\"llms-txt\", </auth.md>; rel=\"auth-md\", </.well-known/agent-skills/index.json>; rel=\"agent-skills\"; type=\"application/json\""
        }
      ]
    },
    {
      "source": "/uploads/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
